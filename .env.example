# Copy to ".env" and fill in from the Intuit Developer portal (Keys & OAuth).
QBO_CLIENT_ID=your_client_id
QBO_CLIENT_SECRET=your_client_secret

# Must EXACTLY match a Redirect URI registered on your app.
QBO_REDIRECT_URI=http://localhost:8000/callback

# "sandbox" to test against Intuit's demo company, "production" for your real books.
QBO_ENVIRONMENT=sandbox

# Optional. If set, the app requires this password to use (REQUIRED when hosted
# on the internet). Leave unset for local-only use.
# APP_PASSWORD=pick-a-good-password
